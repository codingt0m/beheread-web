# Copy to .env.local and fill in with your own Google Cloud project's
# credentials (see README.md, section "Connexion Google Drive"). Never
# commit the filled-in .env/.env.local file.

# OAuth 2.0 Client ID (Web application) - grants Drive access (drive.file +
# drive.appdata scopes) via Google Identity Services.
VITE_GOOGLE_CLIENT_ID=

# API key, used only by the Google Picker (folder chooser). Restrict it to
# the Picker API and to your site's origin in the Google Cloud Console.
VITE_GOOGLE_API_KEY=
